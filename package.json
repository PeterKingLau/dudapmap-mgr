{
  "name": "electronic_fence",
  "version": "1.0.0",
  "description": "Huaxinda React management platform",
  "author": "",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:network",
    "dev:network": "vite --host 0.0.0.0",
